# DSMC-hosted voxel/ISTHMUS sphere ablation with a reset reservoir.
# Each coupling update deletes the gas and recreates a fresh uniform air
# reservoir before sampling one DSMC step of O2 -> CO + CO surface chemistry.
# This imposes the uniform-gas analytical condition while still exercising
# DSMC reaction tallies, triangle-to-voxel mapping, normal carryover, deletion,
# and repeated ISTHMUS remeshing.

shell               mkdir -p output

seed                12345
dimension           3
global              nrho 7.244e23 fnum 5.0e11 gridcut 0.0 surfmax 2000 splitmax 200 comm/sort yes nedgebadnum 50
timestep            1.0e-7

boundary            o o o
create_box          -1.5e-3 1.5e-3 -1.5e-3 1.5e-3 -1.5e-3 1.5e-3
create_grid         10 10 10

species             air.species O2 N2 CO
mixture             air O2 frac 0.21
mixture             air N2 frac 0.79
mixture             air CO frac 0.0
mixture             air temp 5000.0 vstream 0.0 0.0 0.0
collide             vss air air.vss

voxel material carbon density 1800.0
voxel create solid sphere diameter 1.0e-3 resolution 10 material carbon
isthmus surface skin voxels solid buffer 1 weighting no map yes
surface install skin particle none type 1

surf_collide        1 diffuse 5000.0 1.0
surf_react          ox prob carbon-co.surf
surf_modify         all collide 1 react ox
compute             rco react/surf all ox
create_particles    air n 0 twopass

stats_style         step cpu np nscoll nscheck
stats_modify        flush yes
stats               100000

variable            i loop 100
label               coupled-loop

scale_particles     air 0.0
create_particles    air n 0 twopass

fix                 rco ave/surf all 1 1 1 c_rco[*] ave one
run                 1 post no

surface flux skin dsmc/reaction fix rco column 1 sample-steps 1 solid-mass-per-reaction 3.98894696e-26 time-scale 10000
unfix               rco
voxel ablate solid surface skin policy carryover/normal delete yes

remove_surf         all
isthmus surface skin voxels solid buffer 1 weighting no map yes
surface install skin particle none type 1
surf_modify         all collide 1 react ox

next                i
jump                SELF coupled-loop

voxel write-history solid output/history.csv
