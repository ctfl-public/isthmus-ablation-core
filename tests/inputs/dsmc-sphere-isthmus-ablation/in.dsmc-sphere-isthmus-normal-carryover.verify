# DSMC-hosted no-gas ISTHMUS sphere ablation verification.
# This mirrors the standalone conservative normal-carryover sphere path while
# using DSMC as the input host.

voxel_material carbon density 1800.0
voxel_create solid sphere diameter 1.0e-3 resolution 20 material carbon

source q1 constant 0.8 units kg/m2/s
iac stats 1
iac stats_style step time active-voxels deleted-voxels remaining-mass mass-fraction radius requested-mass-step applied-mass-step dropped-mass-step
voxel_dump hist solid history 1 output/dsmc-sphere-isthmus-normal/history.csv
voxel_dump vox solid vtu 1 output/dsmc-sphere-isthmus-normal/voxels_*.vtu select active scalar mass-fraction
surf_dump skin skin vtp 1 output/dsmc-sphere-isthmus-normal/surface_*.vtp
iac timestep mass/courant 0.5 source q1

variable i loop 4
label ablate-loop
isthmus_surf skin voxels solid buffer 1 weighting no map yes
surf_flux skin source q1 select all
voxel_ablate solid surface skin policy carryover/normal delete yes
next i
jump SELF ablate-loop

iac verify radius exact "initial-radius - q1*time/rho" tolerance 4.0 percent norm final
iac verify mass-fraction exact "((initial-radius - q1*time/rho)/initial-radius)^3" tolerance 12.0 percent norm final
iac verify dropped-mass-step exact "0.0" tolerance 0.01 absolute norm final
