# Regression wrapper for the conservative normal-carryover ISTHMUS sphere path.

include             examples/sphere-isthmus-ablation/in.sphere-isthmus-normal

voxel_dump          off
surf_dump           off

iac_verify          rad exact "rad0 - q1*time/rho" tolerance 4.0 percent norm final
iac_verify          mf exact "((rad0 - q1*time/rho)/rad0)^3" tolerance 12.0 percent norm final
iac_verify          mdrop exact "0.0" tolerance 0.01 absolute norm final
