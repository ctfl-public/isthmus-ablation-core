# Regression wrapper for the conservative normal-carryover ISTHMUS sphere path.

include ../../../examples/sphere-isthmus-ablation/in.sphere-isthmus-normal

voxel dump off
surface dump off

verify radius exact "initial-radius - q1*time/rho" tolerance 4.0 percent norm final
verify mass-fraction exact "((initial-radius - q1*time/rho)/initial-radius)^3" tolerance 12.0 percent norm final
verify dropped-mass-step exact "0.0" tolerance 0.01 absolute norm final
