# Regression wrapper for the ISTHMUS sphere ablation path.
# The example owns the case setup. This file adds only test criteria.

include ../../../examples/sphere-isthmus-ablation/in.sphere-isthmus-ablation

voxel dump off
surface dump off

verify radius exact "initial-radius - q1*time/rho" tolerance 7.0 percent norm final
verify mass-fraction exact "((initial-radius - q1*time/rho)/initial-radius)^3" tolerance 20.0 percent norm final
