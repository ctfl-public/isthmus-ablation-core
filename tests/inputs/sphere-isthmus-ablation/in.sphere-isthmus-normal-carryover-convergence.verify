# Convergence wrapper for normal-carryover ISTHMUS sphere ablation.

units               si

variable            resolution equal 20
variable            steps equal 4

voxel_material      carbon density 1800.0
voxel_create        solid sphere diameter 1.0e-3 resolution ${resolution} material carbon

source              q1 constant 0.8 units kg/m2/s
iac_timestep        mass/courant 0.25 source q1

iac_stats           1000000
iac_stats_style     step time nvox ndel mass mf vf rad mreq mapp mdrop

variable            i loop ${steps}
label               ablate-loop
isthmus_surface     skin voxels solid buffer 3 resolution 1.6 iso 0.6 map yes
surf_flux           skin source q1 select all
voxel_ablate        solid surface skin policy carryover/normal delete yes
iac_run             1
next                i
jump                SELF ablate-loop

convergence         rad exact "rad0 - q1*time/rho" tolerance 100.0 percent norm final vary resolution 5 10 20 vary steps 1 2 4 order 0.75 3.0 monotonic yes
convergence         vf exact "((rad0 - q1*time/rho)/rad0)^3" tolerance 100.0 percent norm final vary resolution 5 10 20 vary steps 1 2 4 order 0.75 2.5 monotonic no
