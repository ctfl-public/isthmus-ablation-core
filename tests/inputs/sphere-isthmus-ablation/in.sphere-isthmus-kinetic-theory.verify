# Regression wrapper for kinetic-theory triangle flux on a conservative sphere.

include             examples/sphere-isthmus-ablation/in.sphere-isthmus-kinetic

voxel_dump          off
surf_dump           off

iac_verify          rad exact "rad0 - qkin*time/rho" tolerance 4.0 percent norm final
iac_verify          mf exact "((rad0 - qkin*time/rho)/rad0)^3" tolerance 12.0 percent norm final
iac_verify          mdrop exact "0.0" tolerance 0.01 absolute norm final
