# Regression wrapper for kinetic-theory triangle flux on a conservative sphere.

include ../../../examples/sphere-isthmus-ablation/in.sphere-isthmus-kinetic

voxel_dump off
surf_dump off

verify radius exact "initial-radius - qkin*time/rho" tolerance 4.0 percent norm final
verify mass-fraction exact "((initial-radius - qkin*time/rho)/initial-radius)^3" tolerance 12.0 percent norm final
verify dropped-mass-step exact "0.0" tolerance 0.01 absolute norm final
