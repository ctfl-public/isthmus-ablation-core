# Regression wrapper for the nonconservative ISTHMUS sphere ablation path.

include             examples/sphere-isthmus-ablation/in.sphere-isthmus-local

voxel_dump          off
surf_dump           off

iac_verify          rad exact "rad0 - q1*time/rho" tolerance 7.0 percent norm final
iac_verify          mf exact "((rad0 - q1*time/rho)/rad0)^3" tolerance 20.0 percent norm final
