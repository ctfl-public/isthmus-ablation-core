# Regression wrapper for the DSMC boundary convergence example.
# The example owns the runnable case setup. This file adds only test criteria.

include             examples/dsmc-boundary-mass-flux/in.converge-boundary

iac_verify          dsmc-converged exact "1.0" tolerance 0.0 percent
iac_verify          dsmc-converge-iter exact "1.0" tolerance 200.0 percent
iac_verify          dsmc-converge-positive-support exact "1.0" tolerance 0.0 percent
