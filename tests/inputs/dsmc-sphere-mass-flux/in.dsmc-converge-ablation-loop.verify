# DSMC-hosted coupled loop regression.
# This exercises the combined path that the split converge and ablation tests
# do not cover: converge DSMC mass flux, apply it to IAC, ablate, reinstall the
# surface, and repeat.

seed                12345
dimension           3
global              nrho 7.244e23 fnum 2.0e12 gridcut 0.0 surfmax 2000 splitmax 200 comm/sort yes
timestep            1.0e-7

boundary            p p p
create_box          -1.5e-3 1.5e-3 -1.5e-3 1.5e-3 -1.5e-3 1.5e-3
create_grid         8 8 8
balance_grid        rcb cell

species             examples/dsmc-sphere-mass-flux/air-react-to-flux.species O2 N2 CO
mixture             air O2 frac 1.0
mixture             air N2 frac 0.0
mixture             air CO frac 0.0
mixture             air temp 5000.0 vstream 0.0 0.0 0.0
collide             vss air examples/dsmc-sphere-mass-flux/air-react-to-flux.vss

voxel_material      carbon density 1800.0 molar-mass 0.0120107 formula C
voxel_create        solid sphere diameter 1.0e-3 resolution 4 material carbon
isthmus_surface     skin voxels solid buffer 3 map yes
surf_install        skin particle none type 1

surf_collide        1 diffuse 5000.0 1.0
surf_react          ox prob examples/dsmc-sphere-kinetic/carbon-co.surf
surf_modify         all collide 1 react ox

compute             mflux react/surf/mass/flux all ox mass 0.0240214 norm flux
create_particles    air n 0 twopass

stats_style         step cpu np nscoll nscheck nsreact
stats               100000
iac_stats           1
iac_stats_style     step time nvox ndel mf vf

variable            iter loop 2
label               coupled-loop

  fix               mflux ave/surf all 1 1 1 c_mflux[*] ave one
  dsmc_converge     flux skin fix mflux quantity mass-flux every 1 &
                      reduce sum-area rel 2.0 cv 1.0 window 1 min-iter 1 max-iter 1
  surf_flux         skin dsmc/mass-flux fix mflux quantity mass-flux units flux mass-courant 1.0
  unfix             mflux
  voxel_ablate      solid surface skin policy carryover/normal delete yes
  iac_run           1

  remove_surf       all
  isthmus_surface   skin voxels solid buffer 3 map yes
  surf_install      skin particle none type 1
  surf_modify       all collide 1 react ox

  next              iter
  jump              SELF coupled-loop

iac_verify          dsmc-converged exact "1.0" tolerance 0.0 percent
iac_verify          step exact "2" tolerance 0.0 absolute norm final
iac_verify          mf exact "0.25" tolerance 0.20 absolute norm final
