# Regression wrapper for the DSMC direct mass-flux ablation example.
# The example owns the runnable case setup. This file adds only test criteria.

include             examples/dsmc-sphere-mass-flux/in.ablation-step

iac_verify          mf exact "0.511" tolerance 10.0 percent norm final
iac_verify          vf exact "0.969" tolerance 5.0 percent norm final
