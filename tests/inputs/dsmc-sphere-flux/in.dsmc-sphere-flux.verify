# Regression wrapper for the DSMC reaction-count flux measurement example.
# The example owns the runnable case setup. This file adds only test criteria.

include             examples/dsmc-sphere-flux/in.measure-reaction-flux

iac_verify          area exact area-exact tolerance 2.0 percent
iac_verify          nreact exact nreact-exact tolerance 15.0 percent
iac_verify          rmflux exact rmflux-exact tolerance 15.0 percent
