# DSMC-hosted instantaneous fixed-surface chemistry flux verification.
# This case does not ablate. It checks the initial O2 reaction count and
# equivalent carbon mass flux before local O2 depletion develops.

seed                12345
dimension           3
global              nrho 7.244e23 fnum 2.0e12 gridcut 0.0 surfmax 2000 splitmax 200 comm/sort yes
timestep            1.0e-7

boundary            o o o
create_box          -1.5e-3 1.5e-3 -1.5e-3 1.5e-3 -1.5e-3 1.5e-3
create_grid         10 10 10

species             examples/dsmc-sphere-kinetic/air.species O2 N2 CO
mixture             air O2 frac 0.21
mixture             air N2 frac 0.79
mixture             air CO frac 0.0
mixture             air temp 5000.0 vstream 0.0 0.0 0.0
collide             vss air examples/dsmc-sphere-kinetic/air.vss

voxel material carbon density 1800.0 molar-mass 0.0120107 formula C
voxel create solid sphere diameter 1.0e-3 resolution 10 material carbon
isthmus surface skin voxels solid buffer 1 weighting no map yes
surface install skin particle none type 1

surf_collide        1 diffuse 5000.0 1.0
surf_react          ox prob examples/dsmc-sphere-kinetic/carbon-co.surf
surf_modify         all collide 1 react ox

compute             rco react/surf all ox
fix                 rco ave/surf all 1 1 1 c_rco[*] ave one

create_particles    air n 0 twopass
fix                 reservoir emit/face air all twopass

stats_style         step cpu np nscoll nscheck
stats               1
run                 1 post no

surface measure-flux skin dsmc/reaction fix rco column 1 sample-steps 1 expected kinetic/theory number-density 7.244e23 mole-fraction 0.21 temperature 5000.0 molecular-mass 5.31352e-26 reaction examples/dsmc-sphere-kinetic/carbon-co.surf

iac verify surface-area exact expected-surface-area tolerance 2.0 percent
iac verify reaction-count-per-step exact expected-reaction-count-per-step tolerance 5.0 percent
iac verify reaction-mass-flux exact expected-reaction-mass-flux tolerance 5.0 percent
